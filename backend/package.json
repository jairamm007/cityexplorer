{
  "name": "cityexplorer-backend",
  "version": "1.0.0",
  "description": "Backend API for CityExplorer MERN travel app",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seeder.js",
    "seed:featured": "node scripts/upsertFeaturedCities.js",
    "seed:india": "node scripts/seedIndianCities.js",
    "seed:focus": "node scripts/focusCityDataset.js",
    "seed:admin": "node scripts/createAdmin.js",
